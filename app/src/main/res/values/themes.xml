<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TermKeyIME" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/terminal_green</item>
        <item name="colorPrimaryVariant">@color/terminal_green_dim</item>
        <item name="colorOnPrimary">@color/terminal_bg</item>
        <item name="colorSecondary">@color/terminal_cyan</item>
        <item name="colorOnSecondary">@color/terminal_bg</item>
        <item name="android:colorBackground">@color/terminal_bg</item>
        <item name="android:textColorPrimary">@color/terminal_text</item>
        <item name="android:statusBarColor">@color/terminal_surface</item>
        <item name="android:navigationBarColor">@color/terminal_bg</item>
    </style>

    <!-- Key button style base -->
    <style name="Widget.TermKey.Key" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_key</item>
        <item name="android:textColor">@color/terminal_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.TermKey.Key.Ctrl">
        <item name="android:textColor">@color/terminal_amber</item>
        <item name="android:background">@drawable/bg_key_ctrl</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="Widget.TermKey.Key.Alt">
        <item name="android:textColor">@color/terminal_cyan</item>
        <item name="android:background">@drawable/bg_key_alt</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="Widget.TermKey.Key.Esc">
        <item name="android:textColor">@color/terminal_red</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="Widget.TermKey.Key.Enter">
        <item name="android:textColor">@color/terminal_green</item>
        <item name="android:background">@drawable/bg_key_enter</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Arrays for settings -->
    <array name="key_height_entries_ref">
        <item>@string/app_name</item>
    </array>
</resources>
