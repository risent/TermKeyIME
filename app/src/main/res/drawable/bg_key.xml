<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <solid android:color="#1A3A1A" />
                    <stroke android:width="1dp" android:color="#00E676" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Normal state: key with bottom shadow to give 3D look -->
    <item>
        <layer-list>
            <!-- Shadow/bottom layer -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <solid android:color="#0D1A0D" />
                </shape>
            </item>
            <!-- Main key surface -->
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <solid android:color="#111811" />
                    <stroke android:width="1dp" android:color="#1E2E1E" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
