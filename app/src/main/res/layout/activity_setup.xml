<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TERMKEY"
            android:textColor="@color/terminal_green"
            android:textSize="28sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linux Terminal Keyboard"
            android:textColor="@color/terminal_text_dim"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/setup_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking status…"
            android:textColor="@color/terminal_text_dim"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="@color/terminal_surface"
            android:layout_marginBottom="24dp" />

        <!-- Step 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step1"
            android:textColor="@color/terminal_amber"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_enable_ime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_btn_enable"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/terminal_green" />

        <!-- Step 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step2"
            android:textColor="@color/terminal_amber"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_switch_ime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_btn_switch"
            android:layout_marginBottom="32dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/terminal_green" />

        <!-- Settings -->
        <Button
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_btn_settings"
            style="@style/Widget.MaterialComponents.Button"
            android:backgroundTint="@color/terminal_green"
            android:textColor="@color/terminal_bg" />

        <Button
            android:id="@+id/btn_open_test_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/setup_btn_test_page"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/terminal_green" />

    </LinearLayout>
</ScrollView>
